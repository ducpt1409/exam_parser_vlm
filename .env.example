# ===== exam_parser_vlm — cấu hình (copy thành .env) =====

# --- Chọn backend detector ---
# vllm  = OpenAI-compatible API (KHUYẾN NGHỊ, 100% GPU)
# ollama = Ollama /api/chat (dễ dựng, có thể split CPU nếu thiếu VRAM)
DETECTOR_BACKEND=vllm

# --- vLLM (khi DETECTOR_BACKEND=vllm) ---
# Cấu hình đã chạy được trên 5090 (~17.8GB free). Port 8001 khớp lệnh serve trong SETUP.md §3.1.
VLM_BASE_URL=http://localhost:8001/v1
VLM_MODEL=Qwen/Qwen3-VL-4B-Instruct-FP8
VLM_API_KEY=EMPTY
# Khi giải phóng được VRAM (tắt model Windows ~13GB) có thể nâng cấp (xem SETUP §3.2):
# VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct-FP8
# VLM_MODEL=Qwen/Qwen3-VL-32B-Instruct-FP8

# --- Ollama (khi DETECTOR_BACKEND=ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3-vl:8b

# --- VLM chung ---
VLM_TIMEOUT=600            # giây/trang; trang dày sinh JSON lâu (4B + eager + guided_json chậm)
VLM_MAX_OUTPUT_TOKENS=6000 # chặn output để 1 trang không sinh vô tận → tránh timeout
# Giới hạn pixel ảnh gửi VLM. Nên KHỚP với --mm-processor-kwargs max_pixels của vLLM (SETUP §3.1).
# 2304000 (~2.3M): nét tốt cho A4 dày, bù cho model 4B nhỏ.
VLM_MAX_PIXELS=2304000
VLM_TEMPERATURE=0

# --- Preprocess ---
RENDER_DPI=300
DO_DESKEW=true
DESKEW_THRESHOLD_DEGREES=0.5

# --- Detection scope ---
# false = chỉ khoanh VÙNG CÂU HỎI trọn vẹn (đã gồm phương án bên trong); KHÔNG tách/không vẽ từng đáp án.
# Đặt false cho POC hiện tại (giảm tải model 4B → ít gộp câu, ít cắt sai). true = tách riêng A/B/C/D.
DETECT_ANSWERS=false

# --- Box-snap ---
SNAP_PAD=8                 # padding px sau khi snap khít ink
SNAP_ENABLED=true

# --- Output ---
OUTPUT_DIR=./output
SAVE_VLM_RAW=true          # lưu JSON thô VLM trả về (debug)

# --- Logging ---
LOG_LEVEL=INFO
