# ===== exam_parser_vlm — cấu hình (copy thành .env) =====

# --- Chọn backend detector ---
# vllm  = OpenAI-compatible API (KHUYẾN NGHỊ, 100% GPU)
# ollama = Ollama /api/chat (dễ dựng, có thể split CPU nếu thiếu VRAM)
DETECTOR_BACKEND=vllm

# --- vLLM (khi DETECTOR_BACKEND=vllm) ---
VLM_BASE_URL=http://localhost:8000/v1
VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct-AWQ
VLM_API_KEY=EMPTY
# Khi giải phóng được VRAM (tắt model Windows 13GB) có thể đổi sang:
# VLM_MODEL=Qwen/Qwen3-VL-32B-Instruct-AWQ

# --- Ollama (khi DETECTOR_BACKEND=ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3-vl:8b

# --- VLM chung ---
VLM_TIMEOUT=180
# Giới hạn pixel ảnh gửi VLM (cân bằng độ nét marker vs VRAM/tốc độ). ~1.5M = nét tốt cho A4 dày.
VLM_MAX_PIXELS=1500000
VLM_TEMPERATURE=0

# --- Preprocess ---
RENDER_DPI=300
DO_DESKEW=true
DESKEW_THRESHOLD_DEGREES=0.5

# --- Box-snap ---
SNAP_PAD=8                 # padding px sau khi snap khít ink
SNAP_ENABLED=true

# --- Output ---
OUTPUT_DIR=./output
SAVE_VLM_RAW=true          # lưu JSON thô VLM trả về (debug)

# --- Logging ---
LOG_LEVEL=INFO
